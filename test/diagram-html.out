-> GATE_nand_4__0__0:Y:n [label=\" \", arrowsize = .5 penwidth= 2];\nGATE_nand_4__0__0:Z:s -> GATE_not_4__OUTPUTS:__VIRTUAL__2 [label=\" \", arrowsize = .5 penwidth= 2];\nGATE_not_4__INPUTS:x -> COPY_4__1:x:n [label=\" \", arrowsize = .5 penwidth= 2 , dir = none];\n}\n";
